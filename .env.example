# Application
APP_ENVIRONMENT=dev
APP_NAME=serverless-mern
LOG_LEVEL=info

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# DynamoDB
DYNAMODB_USERS_TABLE=users-dev
DYNAMODB_ORDERS_TABLE=orders-dev
DYNAMODB_NOTIFICATIONS_TABLE=notifications-dev

# Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxx
COGNITO_CLIENT_ID=xxxxx
COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxx

# EventBridge
EVENT_BUS_NAME=serverless-mern-dev

# S3
S3_UPLOADS_BUCKET=serverless-mern-uploads-dev
S3_ASSETS_BUCKET=serverless-mern-assets-dev

# SES
SES_FROM_EMAIL=noreply@example.com
SES_REGION=us-east-1

# Lambda
LAMBDA_TIMEOUT=30
LAMBDA_MEMORY_SIZE=512

# Database (if using RDS in future)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=serverless_mern
DB_USER=postgres
DB_PASSWORD=password

# API Gateway
API_STAGE=dev
API_ENDPOINT=http://localhost:3000

# Frontend
REACT_APP_API_URL=http://localhost:3000
REACT_APP_COGNITO_DOMAIN=serverless-mern-dev.auth.us-east-1.amazoncognito.com
REACT_APP_COGNITO_CLIENT_ID=xxxxx
REACT_APP_COGNITO_REGION=us-east-1

# Local Development (LocalStack)
LOCALSTACK_ENDPOINT=http://localhost:4566
LOCALSTACK_DOCKER_HOST=docker.for.mac.localhost

# Feature Flags
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_ANALYTICS=true
